# Android Emulator:
EXPO_PUBLIC_API_URL=http://10.0.2.2:3334/api

# Celular fisico na mesma rede Wi-Fi:
# Descubra o IP com `ipconfig` e substitua SEU_IP_LOCAL.
# EXPO_PUBLIC_API_URL=http://SEU_IP_LOCAL:3334/api

# Compatibilidade com a versão inicial do setup:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3334/api
EXPO_PUBLIC_API_TIMEOUT_MS=15000
