# Server
NODE_ENV=development
HOST="0.0.0.0"
PORT=3334
APP_NAME="FinSync API"
API_URL="http://localhost:3334"
LOG_LEVEL="debug"

# Database
DATABASE_URL=""

# Auth
JWT_SECRET=""
JWT_EXPIRES_IN="7d"
JWT_ISSUER="finsync-api"
JWT_AUDIENCE="finsync-web"

# CORS
FRONTEND_URL="http://localhost:5174"
CORS_ORIGIN="http://localhost:5174"
CORS_ALLOWED_ORIGINS="http://localhost:5174,http://127.0.0.1:5174"

# Optional legacy Open Finance / Pluggy
ENABLE_PLUGGY=false
OPEN_FINANCE_PROVIDER="disabled"

# Microsoft OneDrive
MICROSOFT_CLIENT_ID=""
MICROSOFT_TENANT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_REDIRECT_URI="http://localhost:3334/api/onedrive/callback"
MICROSOFT_SCOPES="offline_access Files.Read User.Read"
TOKEN_ENCRYPTION_SECRET=""

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
